rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {

    // 認証済みユーザーのみアクセス可
    function isAuthenticated() {
      return request.auth != null;
    }

    // AI執事 (topicsコレクション)
    match /topics/{id} {
      allow read, write: if isAuthenticated();
    }

    // 情報元
    match /sources/{id} {
      allow read, write: if isAuthenticated();
    }

    // レポート (digestsコレクション) - 生成はFunctions経由なので書き込みは禁止
    match /digests/{id} {
      allow read: if isAuthenticated();
      allow write: if false; // Functions (Admin SDK) のみ書き込み可
    }

    // 記事 - フェッチはFunctionsが行うため読み取りのみ
    match /articles/{id} {
      allow read: if isAuthenticated();
      allow write: if false; // Functions (Admin SDK) のみ書き込み可
    }
  }
}
